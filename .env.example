# Copy to .env and adjust. Secrets/tokens live here only — never in code (DEC-26).

# --- LLM (Ollama) — required for live dialogue ---
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=qwen3:8b

# --- ASR (faster-whisper / CTranslate2) ---
# For real Vietnamese WER, point ASR_MODEL at a PhoWhisper-medium CT2 export
# (see scenarios/audio/README.md). The label "phowhisper-medium" is a placeholder,
# not a loadable faster-whisper name — set a real CT2 path or a size like "medium".
ASR_MODEL=phowhisper-medium
# GPU: set ASR_DEVICE=cuda + ASR_COMPUTE_TYPE=float16 and `pip install -e ".[gpu]"`
# (measured ~12x faster ASR on RTX 5070). CPU default below works everywhere.
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8

# --- TTS (optional, +5 pts). none/off => text-only ---
TTS_ENGINE=piper
PIPER_BINARY=piper
PIPER_VOICE=
PIPER_SPEAKER=
PIPER_SAMPLE_RATE=22050

# --- Eval-only LLM-as-judge (cloud / stronger model) ---
# Empty => judge is skipped. The submitted bot does NOT depend on this at inference time.
JUDGE_MODEL=
JUDGE_HOST=

# --- HuggingFace token (only if pulling gated ASR weights) ---
HF_TOKEN=
