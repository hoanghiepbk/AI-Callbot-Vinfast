# Copy to .env and adjust. Secrets/tokens live here only — never in code (DEC-26).

# --- LLM (Ollama) — required for live dialogue ---
# 127.0.0.1 (not localhost): "localhost" reconnects via IPv6 ::1 first after httpx's 5s idle
# keep-alive, stalling ~2s per turn before falling back to IPv4. 127.0.0.1 keeps turns ~0.7s.
OLLAMA_HOST=http://127.0.0.1:11434
LLM_MODEL=qwen3:8b
# Keep qwen3:8b resident in VRAM between turns so a pause never pays a ~6s reload spike
# (-1 = forever; the model is ~5.6 GB, fine on a 12 GB card).
OLLAMA_KEEP_ALIVE=-1

# --- ASR (faster-whisper / CTranslate2) ---
# For real Vietnamese WER, point ASR_MODEL at a PhoWhisper-medium CT2 export
# (see scenarios/audio/README.md). The label "phowhisper-medium" is a placeholder,
# not a loadable faster-whisper name — set a real CT2 path or a size like "medium".
ASR_MODEL=phowhisper-medium
# Demo machine has an NVIDIA GPU -> cuda + float16 (measured ~12x faster ASR on RTX 5070,
# needs `pip install -e ".[gpu]"`). On a machine WITHOUT a GPU, set cpu + int8 instead.
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=float16

# --- TTS (optional, +5 pts). none/off => text-only ---
# piper = local/offline — the CANONICAL demo voice (100% local, no network round-trip).
# edge = Microsoft neural cloud voice (needs internet, breaks "100% local") — ad-hoc only.
TTS_ENGINE=piper
PIPER_BINARY=piper
PIPER_VOICE=
PIPER_SPEAKER=
PIPER_SAMPLE_RATE=22050
EDGE_VOICE=vi-VN-HoaiMyNeural

# Voice backchannel: 1 => play "dạ vâng ạ" the instant audio arrives, masking ASR+LLM latency.
VOICE_FILLER=0

# --- Eval-only LLM-as-judge (cloud / stronger model) ---
# Empty => judge is skipped. The submitted bot does NOT depend on this at inference time.
JUDGE_MODEL=
JUDGE_HOST=

# --- HuggingFace token (only if pulling gated ASR weights) ---
HF_TOKEN=
